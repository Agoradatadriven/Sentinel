# ─── Sentinel configuration ────────────────────────────────────────────────
# Copy to .env (in backend/) and adjust. Every value has a safe default for local dev.

# App
APP_NAME=Sentinel
ORG_NAME=Agora
ENVIRONMENT=development
TIMEZONE=Asia/Manila

# Database — SQLite locally (zero-setup). For Postgres:
#   DATABASE_URL=postgresql+psycopg2://sentinel:sentinel@localhost:5432/sentinel
DATABASE_URL=sqlite:///./sentinel.db

# Auth / JWT — CHANGE THE SECRET IN PRODUCTION
JWT_SECRET=dev-only-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
COOKIE_NAME=sentinel_session
SECURE_COOKIES=false

# Dev login (pick a seeded user, no OAuth). Disable in production.
DEV_LOGIN_ENABLED=true

# Google OAuth 2.0 (optional; leave blank to use DEV_LOGIN)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Kiosk — if set, kiosk endpoints require this key (X-Kiosk-Key header or ?kiosk_key=).
# Leave blank for local dev (trusted LAN device).
KIOSK_KEY=
